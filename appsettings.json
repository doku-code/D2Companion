{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CompanionApp": {
    "AppName": "D2 Companion",
    "AssetVersion": "20260605-dynamic-refresh",
    "CatalogEndpoint": "/api/catalog",
    "Catalog": {
      "DataDirectory": "data",
      "PrimaryFileName": "catalog.json",
      "SampleFileName": "sample-catalog.json",
      "DatabaseFileName": "companion.sqlite"
    },
    "Styx": {
      "ManageProcess": true,
      "KillExistingOnStart": true,
      "Port": 20676,
      "NodeCommand": "node",
      "NodeArguments": "index.js",
      "AppBaseUrl": "http://127.0.0.1:5178"
    }
  }
}
