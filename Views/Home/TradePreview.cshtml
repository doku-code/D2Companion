@model D2CompanionMvc.ViewModels.HomeIndexViewModel
@{
    Layout = "_D2AppShell";
    ViewData["Title"] = $"{Model.AppName} - Trade Preview";
    ViewData["ShellActive"] = "TradePreview";
    ViewData["ShellBodyClass"] = "d2-shell-page--placeholder d2-shell-page--trade-preview";
}

<main class="d2-shell-placeholder" aria-label="Trade Preview placeholder">
  <h1>Trade Preview</h1>
  <p>
    Trade Preview will become its own workspace for items added from the Gear Viewer selected-item panel.
    This page is a placeholder only; no TradeMaster logic or item queue is wired yet.
  </p>
  <ul>
    <li>Future: selected-item queue from My Characters.</li>
    <li>Future: pricing and comparison workflows.</li>
    <li>Future: no mixing of observed-player browse-only gear into your personal trade queue without explicit rules.</li>
  </ul>
</main>
