{
  "Launcher": {
    "AppUrl": "http://127.0.0.1:5178",
    "MvcProjectPath": "../../../../D2CompanionMvc.csproj",
    "BindMode": "LocalOnly",
    "Port": 5178,

    // NOTE: StartStyxCollector is FALSE here.
    // The MVC app (D2CompanionMvc) already manages Styx internally via
    // StyxProcessService (a hosted background service). If the Desktop launcher
    // also starts Styx, you get EADDRINUSE on port 20676.
    // Set to true ONLY if you are running a standalone Styx outside the MVC app
    // (e.g. from a separate terminal) and you know what you are doing.
    "StartStyxCollector": false,

    // Path is relative to the Desktop exe's AppContext.BaseDirectory.
    // "../../../../styx" resolves to the project root /styx/ folder when running
    // from the default Debug output dir (D2Companion.Desktop/bin/Debug/net8.0-windows*/).
    // This is only used when StartStyxCollector is true.
    "StyxWorkingDirectory": "../../../../styx",
    "StyxCommand": "node",
    "StyxArguments": "index.js"
  }
}
